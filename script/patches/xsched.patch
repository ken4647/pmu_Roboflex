diff --git a/utils/include/xsched/utils/hpf_shm.h b/utils/include/xsched/utils/hpf_shm.h
new file mode 100644
index 0000000..d0a92fa
--- /dev/null
+++ b/utils/include/xsched/utils/hpf_shm.h
@@ -0,0 +1,75 @@
+#pragma once
+
+#include <cstdint>
+#include <memory>
+
+#include "xsched/types.h"
+
+namespace xsched::utils
+{
+
+/// @brief HPF shared memory for lock-free suspend/resume notification.
+/// When GLB+HPF uses this, XServer writes per-device min_priority and clients
+/// read it + futex_wait instead of receiving IPC SchedOperation.
+class HpfShm
+{
+public:
+    static constexpr uint32_t kMagic = 0x58534850;  // "XSHP"
+    static constexpr uint32_t kVersion = 1;
+    static constexpr size_t kMaxDevices = 32;
+
+    struct DeviceSlot
+    {
+        uint64_t device_id;       // XDevice
+        int32_t min_priority;     // atomic: min priority allowed to run
+        int32_t futex_seq;        // atomic: incremented on update for futex_wait
+    } __attribute__((aligned(8)));
+
+    struct ShmLayout
+    {
+        uint32_t magic;
+        uint32_t version;
+        uint32_t num_devices;
+        uint32_t _padding;
+        DeviceSlot slots[kMaxDevices];
+    };
+
+    /// @brief Create (server) or attach (client) to HPF shared memory.
+    /// @param name   shm name, e.g. "/xsched-hpf"
+    /// @param create if true, create and own; if false, attach read-only
+    /// @return valid pointer on success, nullptr on failure
+    static std::unique_ptr<HpfShm> Open(const char *name, bool create);
+
+    /// @brief Remove shared memory object (call on server shutdown).
+    static void Unlink(const char *name);
+
+    ~HpfShm();
+
+    HpfShm(const HpfShm &) = delete;
+    HpfShm &operator=(const HpfShm &) = delete;
+
+    /// @brief Get or add device slot. Returns slot index or -1 on failure.
+    int GetOrAddDevice(XDevice device);
+
+    /// @brief Server: set min_priority for device, wake waiters.
+    void SetDeviceMinPriority(XDevice device, Priority min_prio);
+
+    /// @brief Client: check if priority can run, else futex_wait until change.
+    /// @param device   XDevice for this XQueue
+    /// @param priority this XQueue's priority
+    void WaitUntilCanRun(XDevice device, Priority priority);
+
+    bool IsValid() const { return base_ != nullptr; }
+
+private:
+    HpfShm(void *base, int fd, bool owner);
+
+    DeviceSlot *FindSlot(XDevice device);
+    DeviceSlot *AddDevice(XDevice device);
+
+    void *base_ = nullptr;
+    int fd_ = -1;
+    bool owner_ = false;
+};
+
+} // namespace xsched::utils
