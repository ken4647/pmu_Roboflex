diff --git a/sched/src/policy/hpf_shm.cpp b/sched/src/policy/hpf_shm.cpp
new file mode 100644
index 0000000..3da745d
--- /dev/null
+++ b/sched/src/policy/hpf_shm.cpp
@@ -0,0 +1,45 @@
+#include <map>
+
+#include "xsched/sched/policy/hpf_shm.h"
+
+using namespace xsched::sched;
+
+HpfShmPolicy::HpfShmPolicy(utils::HpfShm *shm)
+    : HighestPriorityFirstPolicy()
+    , shm_(shm)
+{
+    XASSERT(shm_ != nullptr && shm_->IsValid(), "HpfShmPolicy requires valid HpfShm");
+}
+
+void HpfShmPolicy::Sched(const Status &status)
+{
+    if (shm_ == nullptr || !shm_->IsValid()) return;
+
+    // Find the running highest priority task of each device (same as HPF)
+    std::map<XDevice, Priority> running_prio_max;
+    for (auto &s : status.xqueue_status) {
+        if (!s.second->ready) continue;
+        XQueueHandle handle = s.second->handle;
+        Priority priority = GetPriority(handle);
+
+        auto prio_it = running_prio_max.find(s.second->device);
+        if (prio_it == running_prio_max.end()) {
+            running_prio_max[s.second->device] = priority;
+        } else if (priority > prio_it->second) {
+            prio_it->second = priority;
+        }
+    }
+
+    // Write min_priority to shared memory for each device; clients will futex_wait on change
+    for (auto &kv : running_prio_max) {
+        shm_->SetDeviceMinPriority(kv.first, kv.second);
+    }
+
+    // For devices with no ready xqueues, set to PRIORITY_MIN-1 so none can run
+    for (auto &s : status.xqueue_status) {
+        XDevice dev = s.second->device;
+        if (running_prio_max.find(dev) == running_prio_max.end()) {
+            shm_->SetDeviceMinPriority(dev, static_cast<Priority>(PRIORITY_MIN - 1));
+        }
+    }
+}
