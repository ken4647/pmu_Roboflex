@@ -0,0 +1,195 @@
+#include "xsched/utils/hpf_shm.h"
+#include "xsched/utils/log.h"
+#include "xsched/utils/xassert.h"
+
+#if defined(__linux__)
+
+#include <atomic>
+#include <cerrno>
+#include <fcntl.h>
+#include <sys/mman.h>
+#include <sys/stat.h>
+#include <unistd.h>
+#include <linux/futex.h>
+#include <sys/syscall.h>
+
+#include <cstring>
+
+namespace xsched::utils
+{
+
+static int FutexWait(std::atomic<int32_t> *addr, int32_t expected)
+{
+    return syscall(SYS_futex, addr, FUTEX_WAIT, expected, nullptr, nullptr, 0);
+}
+
+static int FutexWake(std::atomic<int32_t> *addr, int n)
+{
+    return syscall(SYS_futex, addr, FUTEX_WAKE, n, nullptr, nullptr, 0);
+}
+
+std::unique_ptr<HpfShm> HpfShm::Open(const char *name, bool create)
+{
+    int fd;
+    if (create) {
+        fd = shm_open(name, O_RDWR | O_CREAT | O_EXCL, 0666);
+        if (fd < 0) {
+            shm_unlink(name);
+            fd = shm_open(name, O_RDWR | O_CREAT, 0666);
+        }
+    } else {
+        fd = shm_open(name, O_RDWR, 0);
+    }
+    if (fd < 0) {
+        XDEBG("HpfShm shm_open %s failed: %s", name, strerror(errno));
+        return nullptr;
+    }
+
+    size_t size = sizeof(ShmLayout);
+    if (create) {
+        if (ftruncate(fd, size) != 0) {
+            XERRO("HpfShm ftruncate failed");
+            close(fd);
+            if (create) shm_unlink(name);
+            return nullptr;
+        }
+    }
+
+    void *base = mmap(nullptr, size, PROT_READ | PROT_WRITE, MAP_SHARED, fd, 0);
+    if (base == MAP_FAILED) {
+        XERRO("HpfShm mmap failed");
+        close(fd);
+        if (create) shm_unlink(name);
+        return nullptr;
+    }
+
+    auto shm = std::make_unique<HpfShm>(base, fd, create);
+    if (create) {
+        auto *layout = static_cast<ShmLayout *>(base);
+        layout->magic = kMagic;
+        layout->version = kVersion;
+        layout->num_devices = 0;
+        memset(layout->slots, 0, sizeof(layout->slots));
+        for (size_t i = 0; i < kMaxDevices; ++i) {
+            layout->slots[i].min_priority = PRIORITY_MIN - 1;  // none can run until first Sched
+        }
+    } else {
+        auto *layout = static_cast<ShmLayout *>(base);
+        if (layout->magic != kMagic || layout->version != kVersion) {
+            XWARN("HpfShm invalid magic/version");
+            return nullptr;
+        }
+    }
+
+    return shm;
+}
+
+void HpfShm::Unlink(const char *name)
+{
+#if defined(__linux__)
+    shm_unlink(name);
+#endif
+}
+
+HpfShm::HpfShm(void *base, int fd, bool owner)
+    : base_(base), fd_(fd), owner_(owner)
+{
+}
+
+HpfShm::~HpfShm()
+{
+    if (base_) {
+        munmap(base_, sizeof(ShmLayout));
+        base_ = nullptr;
+    }
+    if (fd_ >= 0) {
+        close(fd_);
+        fd_ = -1;
+    }
+}
+
+HpfShm::DeviceSlot *HpfShm::FindSlot(XDevice device)
+{
+    auto *layout = static_cast<ShmLayout *>(base_);
+    for (uint32_t i = 0; i < layout->num_devices && i < kMaxDevices; ++i) {
+        if (layout->slots[i].device_id == device)
+            return &layout->slots[i];
+    }
+    return nullptr;
+}
+
+HpfShm::DeviceSlot *HpfShm::AddDevice(XDevice device)
+{
+    auto *layout = static_cast<ShmLayout *>(base_);
+    if (layout->num_devices >= kMaxDevices) {
+        XWARN("HpfShm device limit reached");
+        return nullptr;
+    }
+    uint32_t idx = layout->num_devices++;
+    layout->slots[idx].device_id = device;
+    layout->slots[idx].min_priority = PRIORITY_MIN - 1;
+    layout->slots[idx].futex_seq = 0;
+    return &layout->slots[idx];
+}
+
+int HpfShm::GetOrAddDevice(XDevice device)
+{
+    auto *slot = FindSlot(device);
+    if (slot) {
+        return static_cast<int>(slot - static_cast<ShmLayout *>(base_)->slots);
+    }
+    if (owner_) {
+        slot = AddDevice(device);
+        return slot ? static_cast<int>(slot - static_cast<ShmLayout *>(base_)->slots) : -1;
+    }
+    return -1;
+}
+
+void HpfShm::SetDeviceMinPriority(XDevice device, Priority min_prio)
+{
+    auto *slot = FindSlot(device);
+    if (!slot) slot = AddDevice(device);
+    if (!slot) return;
+
+    slot->min_priority = min_prio;
+    __atomic_add_fetch(&slot->futex_seq, 1, __ATOMIC_RELEASE);
+    FutexWake(reinterpret_cast<std::atomic<int32_t> *>(&slot->futex_seq), INT32_MAX);
+}
+
+void HpfShm::WaitUntilCanRun(XDevice device, Priority priority)
+{
+    auto *slot = FindSlot(device);
+    if (!slot) return;  // device not in shm yet, allow run
+
+    while (true) {
+        int32_t min_p = __atomic_load_n(&slot->min_priority, __ATOMIC_ACQUIRE);
+        if (priority >= min_p) return;
+
+        int32_t seq = __atomic_load_n(&slot->futex_seq, __ATOMIC_ACQUIRE);
+        FutexWait(reinterpret_cast<std::atomic<int32_t> *>(&slot->futex_seq), seq);
+    }
+}
+
